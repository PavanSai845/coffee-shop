<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Ember & Grounds — Artisan Coffee</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Cormorant+Garamond:wght@300;400;600&family=DM+Mono:wght@300;400&display=swap" rel="stylesheet"/>
  <style>
    :root {
      --espresso: #1a0f0a;
      --dark-roast: #2c1810;
      --medium-roast: #4a2c1a;
      --caramel: #c8843a;
      --gold: #d4a853;
      --cream: #f5e6c8;
      --latte: #e8d5b0;
      --milk-foam: #faf4e8;
      --steam: rgba(245,230,200,0.06);
      --text-light: #f5e6c8;
      --text-muted: rgba(245,230,200,0.55);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { scroll-behavior: smooth; }

    body {
      background-color: var(--espresso);
      color: var(--cream);
      font-family: 'Cormorant Garamond', serif;
      overflow-x: hidden;
      cursor: default;
    }

    /* ── Grain overlay ── */
    body::before {
      content: '';
      position: fixed; inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
      pointer-events: none; z-index: 9999; opacity: 0.4;
    }

    /* ══════════════ NAV ══════════════ */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 1.4rem 4rem;
      background: linear-gradient(to bottom, rgba(26,15,10,0.95) 0%, transparent 100%);
      backdrop-filter: blur(4px);
    }

    .nav-logo {
      font-family: 'Playfair Display', serif;
      font-size: 1.5rem; font-weight: 700;
      color: var(--gold); letter-spacing: 0.04em;
    }

    .nav-logo span { font-style: italic; color: var(--caramel); }

    .nav-links {
      display: flex; gap: 2.5rem; list-style: none;
    }

    .nav-links a {
      font-family: 'DM Mono', monospace;
      font-size: 0.72rem; letter-spacing: 0.14em;
      color: var(--text-muted); text-decoration: none;
      text-transform: uppercase;
      transition: color 0.3s;
    }

    .nav-links a:hover { color: var(--gold); }

    .nav-cta {
      font-family: 'DM Mono', monospace;
      font-size: 0.72rem; letter-spacing: 0.12em;
      text-transform: uppercase;
      background: transparent;
      border: 1px solid var(--caramel);
      color: var(--caramel);
      padding: 0.6rem 1.4rem;
      cursor: pointer;
      transition: all 0.3s;
    }

    .nav-cta:hover {
      background: var(--caramel); color: var(--espresso);
    }

    /* ══════════════ HERO ══════════════ */
    .hero {
      min-height: 100vh;
      display: grid; place-items: center;
      position: relative; overflow: hidden;
      padding: 0 4rem;
    }

    .hero-bg {
      position: absolute; inset: 0;
      background:
        radial-gradient(ellipse 60% 70% at 70% 50%, rgba(74,44,26,0.55) 0%, transparent 70%),
        radial-gradient(ellipse 40% 40% at 20% 80%, rgba(200,132,58,0.12) 0%, transparent 60%),
        linear-gradient(160deg, #1a0f0a 0%, #2c1810 50%, #1a0f0a 100%);
    }

    /* Coffee ring decorations */
    .ring {
      position: absolute;
      border-radius: 50%;
      border: 1px solid rgba(200,132,58,0.15);
      animation: ringPulse 8s ease-in-out infinite;
    }
    .ring-1 { width: 600px; height: 600px; top: -100px; right: -150px; animation-delay: 0s; }
    .ring-2 { width: 400px; height: 400px; top: 50px; right: -50px; animation-delay: 2s; border-color: rgba(200,132,58,0.08); }
    .ring-3 { width: 200px; height: 200px; bottom: 100px; left: 5%; border-color: rgba(200,132,58,0.1); animation-delay: 4s; }

    @keyframes ringPulse {
      0%, 100% { transform: scale(1); opacity: 1; }
      50% { transform: scale(1.05); opacity: 0.6; }
    }

    .hero-content {
      position: relative; z-index: 2;
      max-width: 680px;
      animation: fadeUp 1.2s ease forwards;
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(30px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .hero-eyebrow {
      font-family: 'DM Mono', monospace;
      font-size: 0.68rem; letter-spacing: 0.25em;
      color: var(--caramel); text-transform: uppercase;
      margin-bottom: 1.2rem;
      display: flex; align-items: center; gap: 1rem;
    }

    .hero-eyebrow::before {
      content: ''; width: 40px; height: 1px; background: var(--caramel);
    }

    .hero-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(3.2rem, 7vw, 6rem);
      font-weight: 700; line-height: 1.05;
      color: var(--cream);
      margin-bottom: 1.5rem;
    }

    .hero-title em {
      font-style: italic; color: var(--gold);
      display: block;
    }

    .hero-subtitle {
      font-size: 1.25rem; font-weight: 300;
      color: var(--text-muted); line-height: 1.7;
      max-width: 480px; margin-bottom: 2.5rem;
    }

    .hero-actions { display: flex; gap: 1.2rem; align-items: center; }

    .btn-primary {
      font-family: 'DM Mono', monospace;
      font-size: 0.72rem; letter-spacing: 0.12em;
      text-transform: uppercase;
      background: var(--gold);
      color: var(--espresso);
      border: none; padding: 1rem 2.2rem;
      cursor: pointer; font-weight: 400;
      transition: all 0.3s;
    }

    .btn-primary:hover {
      background: var(--caramel); transform: translateY(-2px);
    }

    .btn-ghost {
      font-family: 'DM Mono', monospace;
      font-size: 0.72rem; letter-spacing: 0.12em;
      text-transform: uppercase;
      background: transparent; border: none;
      color: var(--text-muted); cursor: pointer;
      display: flex; align-items: center; gap: 0.6rem;
      transition: color 0.3s;
    }

    .btn-ghost:hover { color: var(--cream); }

    .hero-stats {
      position: absolute; bottom: 3rem; right: 4rem;
      display: flex; gap: 3rem;
      animation: fadeUp 1.2s ease 0.4s both;
    }

    .stat { text-align: center; }

    .stat-num {
      font-family: 'Playfair Display', serif;
      font-size: 2rem; color: var(--gold); display: block;
    }

    .stat-label {
      font-family: 'DM Mono', monospace;
      font-size: 0.6rem; letter-spacing: 0.15em;
      color: var(--text-muted); text-transform: uppercase;
    }

    /* ══════════════ SECTION SHARED ══════════════ */
    section { padding: 6rem 4rem; }

    .section-label {
      font-family: 'DM Mono', monospace;
      font-size: 0.65rem; letter-spacing: 0.22em;
      text-transform: uppercase; color: var(--caramel);
      display: flex; align-items: center; gap: 1rem;
      margin-bottom: 1rem;
    }

    .section-label::after {
      content: ''; flex: 1; max-width: 60px;
      height: 1px; background: var(--caramel); opacity: 0.5;
    }

    .section-heading {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2rem, 4vw, 3.2rem);
      font-weight: 700; color: var(--cream);
      margin-bottom: 0.5rem;
    }

    .section-heading em { font-style: italic; color: var(--gold); }

    /* ══════════════ ABOUT STRIP ══════════════ */
    .about-strip {
      background: var(--dark-roast);
      padding: 3rem 4rem;
      display: flex; align-items: center;
      gap: 4rem; border-top: 1px solid rgba(200,132,58,0.12);
      border-bottom: 1px solid rgba(200,132,58,0.12);
    }

    .about-strip p {
      font-size: 1.15rem; font-weight: 300;
      color: var(--text-muted); line-height: 1.8;
      max-width: 700px;
    }

    .about-strip p strong { color: var(--gold); font-weight: 600; }

    .about-divider {
      width: 1px; height: 80px;
      background: rgba(200,132,58,0.3);
      flex-shrink: 0;
    }

    .about-tag {
      font-family: 'DM Mono', monospace;
      font-size: 0.65rem; letter-spacing: 0.2em;
      text-transform: uppercase; color: var(--caramel);
      white-space: nowrap;
    }

    /* ══════════════ MENU ══════════════ */
    .menu-section { background: var(--espresso); }

    .menu-header {
      display: flex; justify-content: space-between;
      align-items: flex-end; margin-bottom: 3.5rem;
      flex-wrap: wrap; gap: 1.5rem;
    }

    .menu-filters {
      display: flex; gap: 0.5rem; flex-wrap: wrap;
    }

    .filter-btn {
      font-family: 'DM Mono', monospace;
      font-size: 0.65rem; letter-spacing: 0.12em;
      text-transform: uppercase;
      background: transparent;
      border: 1px solid rgba(200,132,58,0.3);
      color: var(--text-muted);
      padding: 0.5rem 1rem; cursor: pointer;
      transition: all 0.25s;
    }

    .filter-btn.active, .filter-btn:hover {
      border-color: var(--gold);
      color: var(--gold);
      background: rgba(212,168,83,0.07);
    }

    .menu-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 1.5px;
      background: rgba(200,132,58,0.08);
      border: 1px solid rgba(200,132,58,0.08);
    }

    .menu-card {
      background: var(--espresso);
      padding: 2.2rem;
      transition: background 0.3s;
      position: relative;
      overflow: hidden;
      cursor: pointer;
    }

    .menu-card::after {
      content: '';
      position: absolute; bottom: 0; left: 0; right: 0;
      height: 2px;
      background: linear-gradient(90deg, transparent, var(--gold), transparent);
      transform: scaleX(0);
      transition: transform 0.4s ease;
    }

    .menu-card:hover { background: var(--dark-roast); }
    .menu-card:hover::after { transform: scaleX(1); }

    .coffee-icon {
      font-size: 2.4rem; margin-bottom: 1rem;
      display: block;
    }

    .card-category {
      font-family: 'DM Mono', monospace;
      font-size: 0.58rem; letter-spacing: 0.2em;
      text-transform: uppercase; color: var(--caramel);
      margin-bottom: 0.6rem;
    }

    .card-name {
      font-family: 'Playfair Display', serif;
      font-size: 1.4rem; color: var(--cream);
      margin-bottom: 0.6rem;
    }

    .card-desc {
      font-size: 0.92rem; color: var(--text-muted);
      line-height: 1.65; margin-bottom: 1.4rem;
    }

    .card-footer {
      display: flex; justify-content: space-between;
      align-items: center;
    }

    .card-price {
      font-family: 'Playfair Display', serif;
      font-size: 1.2rem; color: var(--gold);
    }

    .card-badge {
      font-family: 'DM Mono', monospace;
      font-size: 0.55rem; letter-spacing: 0.12em;
      text-transform: uppercase;
      background: rgba(200,132,58,0.15);
      border: 1px solid rgba(200,132,58,0.35);
      color: var(--caramel);
      padding: 0.25rem 0.65rem;
    }

    .card-hidden { display: none; }

    /* ══════════════ BREWING METHODS ══════════════ */
    .brew-section {
      background: linear-gradient(135deg, var(--dark-roast) 0%, var(--espresso) 100%);
      border-top: 1px solid rgba(200,132,58,0.12);
    }

    .brew-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 1px; background: rgba(200,132,58,0.1);
      margin-top: 3rem;
    }

    .brew-card {
      background: var(--dark-roast);
      padding: 2rem 1.5rem; text-align: center;
      transition: background 0.3s;
    }

    .brew-card:hover { background: #3a2018; }

    .brew-icon { font-size: 2rem; margin-bottom: 0.8rem; display: block; }

    .brew-name {
      font-family: 'Playfair Display', serif;
      font-size: 1.05rem; color: var(--cream);
      margin-bottom: 0.4rem;
    }

    .brew-desc {
      font-size: 0.82rem; color: var(--text-muted); line-height: 1.5;
    }

    /* ══════════════ ORIGIN / BEANS ══════════════ */
    .origin-section { background: var(--espresso); }

    .origin-grid {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 2rem; margin-top: 3rem;
    }

    .origin-card {
      border: 1px solid rgba(200,132,58,0.12);
      padding: 2rem; position: relative; overflow: hidden;
    }

    .origin-card::before {
      content: '';
      position: absolute; top: 0; left: 0; right: 0; height: 3px;
      background: var(--gradient);
    }

    .origin-card:nth-child(1) { --gradient: linear-gradient(90deg, #c8843a, #d4a853); }
    .origin-card:nth-child(2) { --gradient: linear-gradient(90deg, #8b5a2b, #c8843a); }
    .origin-card:nth-child(3) { --gradient: linear-gradient(90deg, #d4a853, #e8c47a); }

    .origin-flag { font-size: 2rem; margin-bottom: 0.8rem; display: block; }

    .origin-country {
      font-family: 'DM Mono', monospace;
      font-size: 0.65rem; letter-spacing: 0.2em;
      text-transform: uppercase; color: var(--caramel);
      margin-bottom: 0.4rem;
    }

    .origin-name {
      font-family: 'Playfair Display', serif;
      font-size: 1.3rem; color: var(--cream); margin-bottom: 0.8rem;
    }

    .origin-notes {
      font-size: 0.88rem; color: var(--text-muted);
      line-height: 1.6; margin-bottom: 1rem;
    }

    .origin-tags { display: flex; flex-wrap: wrap; gap: 0.4rem; }

    .origin-tag {
      font-family: 'DM Mono', monospace;
      font-size: 0.58rem; letter-spacing: 0.1em;
      background: rgba(200,132,58,0.1);
      border: 1px solid rgba(200,132,58,0.25);
      color: var(--caramel); padding: 0.2rem 0.6rem;
    }

    /* ══════════════ TESTIMONIALS ══════════════ */
    .testimonial-section {
      background: var(--dark-roast);
      border-top: 1px solid rgba(200,132,58,0.12);
    }

    .testimonial-grid {
      display: grid; grid-template-columns: 1fr 1fr 1fr;
      gap: 2rem; margin-top: 3rem;
    }

    .testimonial-card {
      padding: 2rem;
      border-left: 2px solid rgba(200,132,58,0.3);
    }

    .testimonial-stars { color: var(--gold); font-size: 0.85rem; margin-bottom: 1rem; }

    .testimonial-text {
      font-style: italic; font-size: 1.05rem;
      color: var(--text-muted); line-height: 1.75;
      margin-bottom: 1.2rem;
    }

    .testimonial-author {
      font-family: 'DM Mono', monospace;
      font-size: 0.65rem; letter-spacing: 0.15em;
      text-transform: uppercase; color: var(--caramel);
    }

    /* ══════════════ HOURS ══════════════ */
    .hours-section {
      background: var(--medium-roast);
      padding: 4rem;
      display: grid; grid-template-columns: 1fr auto 1fr;
      gap: 4rem; align-items: center;
    }

    .hours-list { list-style: none; }

    .hours-item {
      display: flex; justify-content: space-between;
      padding: 0.7rem 0;
      border-bottom: 1px solid rgba(245,230,200,0.08);
      font-size: 0.95rem;
    }

    .hours-day { color: var(--text-muted); }
    .hours-time { color: var(--gold); font-family: 'DM Mono', monospace; font-size: 0.8rem; }

    .hours-divider {
      width: 1px; background: rgba(200,132,58,0.2);
      align-self: stretch;
    }

    .hours-address { text-align: right; }
    .hours-address h3 {
      font-family: 'Playfair Display', serif;
      font-size: 1.4rem; color: var(--cream); margin-bottom: 0.8rem;
    }

    .hours-address p {
      font-size: 0.95rem; color: var(--text-muted); line-height: 1.8;
    }

    /* ══════════════ FOOTER ══════════════ */
    footer {
      background: #110a06;
      padding: 3rem 4rem;
      display: flex; justify-content: space-between; align-items: center;
      border-top: 1px solid rgba(200,132,58,0.1);
    }

    .footer-logo {
      font-family: 'Playfair Display', serif;
      font-size: 1.2rem; color: var(--gold);
    }

    .footer-copy {
      font-family: 'DM Mono', monospace;
      font-size: 0.6rem; letter-spacing: 0.12em;
      color: var(--text-muted);
    }

    .footer-social { display: flex; gap: 1.5rem; }
    .footer-social a {
      font-family: 'DM Mono', monospace;
      font-size: 0.62rem; letter-spacing: 0.12em;
      text-transform: uppercase; color: var(--text-muted);
      text-decoration: none; transition: color 0.3s;
    }

    .footer-social a:hover { color: var(--gold); }

    /* ══════════════ SCROLL REVEAL ══════════════ */
    .reveal {
      opacity: 0; transform: translateY(24px);
      transition: opacity 0.7s ease, transform 0.7s ease;
    }

    .reveal.visible { opacity: 1; transform: translateY(0); }

    /* ══════════════ RESPONSIVE ══════════════ */
    @media (max-width: 900px) {
      nav { padding: 1.2rem 2rem; }
      .nav-links { display: none; }
      section { padding: 4rem 2rem; }
      .hero { padding: 0 2rem; }
      .hero-stats { right: 2rem; gap: 2rem; }
      .origin-grid, .testimonial-grid { grid-template-columns: 1fr; }
      .hours-section { grid-template-columns: 1fr; }
      .hours-divider { display: none; }
      .hours-address { text-align: left; }
      .about-strip { flex-direction: column; gap: 2rem; }
      footer { flex-direction: column; gap: 1.5rem; text-align: center; }
    }
  </style>
</head>
<body>

  <!-- ── NAV ── -->
  <nav>
    <div class="nav-logo">Ember <span>&</span> Grounds</div>
    <ul class="nav-links">
      <li><a href="#menu">Menu</a></li>
      <li><a href="#origins">Origins</a></li>
      <li><a href="#brew">Brewing</a></li>
      <li><a href="#visit">Visit</a></li>
    </ul>
    <button class="nav-cta">Order Now</button>
  </nav>

  <!-- ── HERO ── -->
  <section class="hero" id="home">
    <div class="hero-bg"></div>
    <div class="ring ring-1"></div>
    <div class="ring ring-2"></div>
    <div class="ring ring-3"></div>

    <div class="hero-content">
      <div class="hero-eyebrow">Est. 2009 &nbsp;·&nbsp; Artisan Coffee</div>
      <h1 class="hero-title">
        Every Cup
        <em>Tells a Story</em>
      </h1>
      <p class="hero-subtitle">
        From sun-drenched Ethiopian highlands to Guatemalan volcanic soil —
        we source, roast, and craft every bean with obsessive care.
      </p>
      <div class="hero-actions">
        <button class="btn-primary" onclick="document.getElementById('menu').scrollIntoView({behavior:'smooth'})">Explore Menu</button>
        <button class="btn-ghost">→ Our Story</button>
      </div>
    </div>

    <div class="hero-stats">
      <div class="stat">
        <span class="stat-num">28+</span>
        <span class="stat-label">Coffee Varieties</span>
      </div>
      <div class="stat">
        <span class="stat-num">12</span>
        <span class="stat-label">Origins</span>
      </div>
      <div class="stat">
        <span class="stat-num">15yr</span>
        <span class="stat-label">Roasting</span>
      </div>
    </div>
  </section>

  <!-- ── ABOUT STRIP ── -->
  <div class="about-strip reveal">
    <p>
      <strong>Ember & Grounds</strong> is a specialty coffee house built on the belief that
      great coffee is a craft — from the farmer's hands to your cup. We roast in small batches,
      brew with precision, and serve with warmth.
    </p>
    <div class="about-divider"></div>
    <div class="about-tag">Small Batch<br/>Roastery</div>
    <div class="about-divider"></div>
    <div class="about-tag">Direct<br/>Trade</div>
    <div class="about-divider"></div>
    <div class="about-tag">Award<br/>Winning</div>
  </div>

  <!-- ══════════ MENU ══════════ -->
  <section class="menu-section" id="menu">
    <div class="menu-header reveal">
      <div>
        <div class="section-label">Our Menu</div>
        <h2 class="section-heading">Crafted <em>Coffees</em></h2>
      </div>
      <div class="menu-filters">
        <button class="filter-btn active" onclick="filterMenu('all', this)">All</button>
        <button class="filter-btn" onclick="filterMenu('espresso', this)">Espresso</button>
        <button class="filter-btn" onclick="filterMenu('milk', this)">Milk Based</button>
        <button class="filter-btn" onclick="filterMenu('black', this)">Black Coffee</button>
        <button class="filter-btn" onclick="filterMenu('cold', this)">Cold & Iced</button>
        <button class="filter-btn" onclick="filterMenu('specialty', this)">Specialty</button>
        <button class="filter-btn" onclick="filterMenu('seasonal', this)">Seasonal</button>
      </div>
    </div>

    <div class="menu-grid reveal" id="menuGrid">

      <!-- ESPRESSO -->
      <div class="menu-card" data-category="espresso">
        <span class="coffee-icon">☕</span>
        <div class="card-category">Espresso</div>
        <div class="card-name">Single Espresso</div>
        <p class="card-desc">A pure, concentrated shot pulled from our house blend. Bold, syrupy, with a thick crema and notes of dark chocolate and dried fruit.</p>
        <div class="card-footer">
          <span class="card-price">₹160</span>
          <span class="card-badge">Signature</span>
        </div>
      </div>

      <div class="menu-card" data-category="espresso">
        <span class="coffee-icon">☕</span>
        <div class="card-category">Espresso</div>
        <div class="card-name">Double Espresso</div>
        <p class="card-desc">Two ristretto shots in perfect harmony. For those who appreciate the full power of the bean — intense, complex, deeply satisfying.</p>
        <div class="card-footer">
          <span class="card-price">₹220</span>
        </div>
      </div>

